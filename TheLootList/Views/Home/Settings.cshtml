@model TriFalcon_Fitness.Models.ApplicationUser
@{
    ViewData["Title"] = "User Profile & Goals";
}

<div class="container mt-5 pb-5" style="min-height: 85vh;">
    <form asp-controller="Home" asp-action="UpdateSettings" method="post">
        <div class="row justify-content-center">
            <div class="col-md-9">
                <h2 class="text-primary mb-4">Profile & Custom Goals</h2>

                @if (TempData["StatusMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["StatusMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* SECTION 1: Biometrics *@
                <div class="card bg-secondary mb-4 border-0 shadow-lg">
                    <div class="card-header bg-dark text-info">
                        <h5 class="mb-0">Personal Details & Biometrics</h5>
                    </div>
                    <div class="card-body text-white p-4">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold" asp-for="FullName">Display Name</label>
                                <input asp-for="FullName" class="form-control bg-dark text-white border-0" placeholder="Athlete Name">
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email Address</label>
                                    <input type="email" class="form-control bg-dark text-white-50 border-0" value="@User.Identity?.Name" readonly>
                                    <small class="text-white-50">Email cannot be changed here.</small>
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-info" asp-for="Weight">Current Weight</label>
                                    <div class="input-group">
                                        <input asp-for="Weight" type="number" step="0.1" class="form-control bg-dark text-white border-0">
                                            <span class="input-group-text bg-dark text-info border-0">lbs</span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold text-success" asp-for="GoalWeight">Goal Body Weight</label>
                                        <div class="input-group">
                                            <input asp-for="GoalWeight" type="number" step="0.1" class="form-control bg-dark text-white border-0">
                                                <span class="input-group-text bg-dark text-success border-0">lbs</span>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold text-light" asp-for="Height">Height</label>
                                            <div class="input-group">
                                                <input asp-for="Height" type="number" step="0.1" class="form-control bg-dark text-white border-0">
                                                    <span class="input-group-text bg-dark text-light border-0">in</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @* SECTION 2: Goals *@
                                <div class="card bg-secondary mb-4 border-0 shadow-lg">
                                    <div class="card-header bg-dark text-info">
                                        <h5 class="mb-0">Custom Performance Milestones</h5>
                                    </div>
                                    <div class="card-body text-white p-4">
                                        <h6 class="text-primary text-uppercase small fw-bold mb-3">Strength Goal</h6>
                                        <div class="row mb-4">
                                            <div class="col-md-6">
                                                <label class="form-label" asp-for="TargetExercise">Exercise Name</label>
                                                <input asp-for="TargetExercise" class="form-control bg-dark text-white border-0" placeholder="e.g. Bench Press">
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label" asp-for="TargetStrengthWeight">Target Weight</label>
                                                    <div class="input-group">
                                                        <input asp-for="TargetStrengthWeight" type="number" class="form-control bg-dark text-white border-0">
                                                            <span class="input-group-text bg-dark text-primary border-0">lbs</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <hr class="border-light opacity-25">

                                                <h6 class="text-primary text-uppercase small fw-bold mb-3">Cardio Goal</h6>
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <label class="form-label" asp-for="TargetCardioType">Activity Type</label>
                                                        <input asp-for="TargetCardioType" class="form-control bg-dark text-white border-0" list="cardioOptions">
                                                            <datalist id="cardioOptions">
                                                                <option value="Running"></option>
                                                                <option value="Cycling"></option>
                                                                <option value="Swimming"></option>
                                                            </datalist>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label" asp-for="TargetDistance">Target Distance</label>
                                                            <div class="input-group">
                                                                <input asp-for="TargetDistance" type="number" step="0.01" class="form-control bg-dark text-white border-0">
                                                                    <span class="input-group-text bg-dark text-white border-0">mi</span>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label" asp-for="TargetDuration">Target Duration</label>
                                                                <div class="input-group">
                                                                    <input asp-for="TargetDuration" type="number" class="form-control bg-dark text-white border-0">
                                                                        <span class="input-group-text bg-dark text-white border-0">min</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 mb-5">
                                                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-lg px-4 border-0">Cancel</a>
                                                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow">Update My Goals</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>