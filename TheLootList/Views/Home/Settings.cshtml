@{
    ViewData["Title"] = "User Profile & Goals";
}

<div class="container mt-5 pb-5" style="min-height: 85vh;">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <h2 class="text-primary mb-4">Profile & Custom Goals</h2>

            <div class="card bg-secondary mb-4 border-0 shadow-lg">
                <div class="card-header bg-dark text-info">
                    <h5 class="mb-0">Personal Details & Biometrics</h5>
                </div>
                <div class="card-body text-white p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Display Name</label>
                            <input type="text" class="form-control bg-dark text-white border-0" placeholder="Athlete Name">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" class="form-control bg-dark text-white border-0" placeholder="athlete@email.com">
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-info">Current Weight (lbs)</label>
                            <input type="number" class="form-control bg-dark text-white border-0" placeholder="0">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-success">Goal Body Weight (lbs)</label>
                            <input type="number" class="form-control bg-dark text-white border-0" placeholder="0">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Height (inches)</label>
                            <input type="number" class="form-control bg-dark text-white border-0" placeholder="0">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card bg-secondary mb-4 border-0 shadow-lg">
                <div class="card-header bg-dark text-info">
                    <h5 class="mb-0">Custom Performance Milestones</h5>
                </div>
                <div class="card-body text-white p-4">
                    <p class="text-white-50 small mb-4">Define your own targets. Type in the exercise or activity you are training for.</p>

                    <h6 class="text-primary text-uppercase small fw-bold mb-3">Strength Goal</h6>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Exercise Name</label>
                            <input type="text" class="form-control bg-dark text-white border-0" placeholder="e.g. Bench Press">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Target Weight (lbs)</label>
                            <input type="number" class="form-control bg-dark text-white border-0" placeholder="225">
                        </div>
                    </div>

                    <hr class="border-light opacity-25">

                    <h6 class="text-primary text-uppercase small fw-bold mb-3">Cardio Goal</h6>
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label">Activity</label>
                            <input type="text" class="form-control bg-dark text-white border-0" placeholder="e.g. 5k Run">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Target Distance</label>
                            <input type="text" class="form-control bg-dark text-white border-0" placeholder="3.1 miles">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Target Time</label>
                            <input type="text" class="form-control bg-dark text-white border-0" placeholder="20:00 mins">
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 mb-5">
                <a asp-action="Index" class="btn btn-outline-light btn-lg px-4 border-0">Cancel</a>
                <button type="button" class="btn btn-primary btn-lg px-5 shadow">Update My Goals</button>
            </div>
        </div>
    </div>
</div>

<div style="height: 50px;"></div>