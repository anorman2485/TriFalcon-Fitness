@model TriFalcon_Fitness.Models.ApplicationUser
@{
    ViewData["Title"] = "Fitness Analytics";
    var workouts = ViewBag.Workouts as List<TriFalcon_Fitness.Models.Workout> ?? new List<TriFalcon_Fitness.Models.Workout>();

    // Group Strength by Exercise Name
    var strengthGroups = workouts
        .Where(w => w.ActivityType == "Strength" && !string.IsNullOrEmpty(w.ExerciseName))
        .GroupBy(w => w.ExerciseName)
        .ToList();

    // Group Cardio by Exercise Name (e.g., Running, Cycling)
    var cardioGroups = workouts
        .Where(w => w.ActivityType == "Cardio" && !string.IsNullOrEmpty(w.ExerciseName))
        .GroupBy(w => w.ExerciseName)
        .ToList();
}

<div class="container mt-5 pb-5">
    <h2 class="text-primary fw-bold mb-4"><i class="fas fa-chart-line me-2"></i>Performance Dashboard</h2>

    @* --- STRENGTH SECTION --- *@
    <h4 class="text-white mb-4 border-bottom border-primary pb-2">Strength Progression</h4>
    <div class="row">
        @foreach (var group in strengthGroups)
        {
            var chartId = "chart_s_" + group.Key.Replace(" ", "_");
            <div class="col-lg-6 mb-4">
                <div class="card bg-dark border-secondary shadow">
                    <div class="card-header bg-success text-white">@group.Key (Weight Lifted)</div>
                    <div class="card-body"><canvas id="@chartId" style="height:250px;"></canvas></div>
                </div>
            </div>
        }
    </div>

    @* --- CARDIO SECTION --- *@
    <h4 class="text-white mt-5 mb-4 border-bottom border-info pb-2">Cardio Milestones</h4>
    <div class="row">
        @foreach (var group in cardioGroups)
        {
            var chartId = "chart_c_" + group.Key.Replace(" ", "_");
            <div class="col-lg-6 mb-4">
                <div class="card bg-dark border-secondary shadow">
                    <div class="card-header bg-info text-white">@group.Key (Distance in Miles)</div>
                    <div class="card-body"><canvas id="@chartId" style="height:250px;"></canvas></div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // Strength Charts (Weight)
        @foreach (var group in strengthGroups)
        {
            var chartId = "chart_s_" + group.Key.Replace(" ", "_");
            <text>
                new Chart(document.getElementById('@chartId'), {
                type: 'line',
                data: {
                labels: @Html.Raw(Json.Serialize(group.OrderBy(w => w.DateLogged).Select(w => w.DateLogged.ToString("MM/dd")))),
                datasets: [{ label: 'lbs', data: @Html.Raw(Json.Serialize(group.OrderBy(w => w.DateLogged).Select(w => w.Weight ?? 0))), borderColor: '#28a745', tension: 0.3, fill: true, backgroundColor: 'rgba(40, 167, 69, 0.1)' }]
                },
                options: { plugins: { legend: { display: false } }, scales: { y: { ticks: { color: '#fff' } }, x: { ticks: { color: '#fff' } } } }
                });
            </text>
        }

        // Cardio Charts (Distance)
        @foreach (var group in cardioGroups)
        {
            var chartId = "chart_c_" + group.Key.Replace(" ", "_");
            <text>
                new Chart(document.getElementById('@chartId'), {
                type: 'line',
                data: {
                labels: @Html.Raw(Json.Serialize(group.OrderBy(w => w.DateLogged).Select(w => w.DateLogged.ToString("MM/dd")))),
                datasets: [{ label: 'miles', data: @Html.Raw(Json.Serialize(group.OrderBy(w => w.DateLogged).Select(w => w.Distance ?? 0))), borderColor: '#17a2b8', tension: 0.3, fill: true, backgroundColor: 'rgba(23, 162, 184, 0.1)' }]
                },
                options: { plugins: { legend: { display: false } }, scales: { y: { ticks: { color: '#fff' } }, x: { ticks: { color: '#fff' } } } }
                });
            </text>
        }
        });
    </script>
}