@model TriFalcon_Fitness.Models.Workout

@{
    ViewData["Title"] = "Edit Workout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card bg-dark text-white shadow-lg border-primary animate__animated animate__fadeIn">
                <div class="card-header border-primary bg-primary bg-opacity-10 py-3">
                    <h3 class="mb-0 text-primary fw-bold"><i class="fas fa-edit me-2"></i>Edit Workout</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        @* CRITICAL: Hidden fields to maintain database integrity *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="DateLogged" />

                        <div class="row g-3">
                            <div class="col-md-12 mb-3">
                                <label asp-for="ExerciseName" class="form-label text-info fw-bold">Exercise Name</label>
                                <input asp-for="ExerciseName" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" placeholder="e.g. Bench Press" />
                                <span asp-validation-for="ExerciseName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ActivityType" class="form-label text-info fw-bold">Activity Type</label>
                                <input asp-for="ActivityType" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="ActivityType" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Weight" class="form-label text-info fw-bold">Weight (lbs)</label>
                                <input asp-for="Weight" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Sets" class="form-label text-info fw-bold">Sets</label>
                                <input asp-for="Sets" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="Sets" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Reps" class="form-label text-info fw-bold">Reps</label>
                                <input asp-for="Reps" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="Reps" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Distance" class="form-label text-info fw-bold">Distance (mi)</label>
                                <input asp-for="Distance" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="Distance" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="DurationMinutes" class="form-label text-info fw-bold">Duration (Minutes)</label>
                                <input asp-for="DurationMinutes" class="form-control bg-secondary bg-opacity-25 text-white border-secondary" />
                                <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light px-4">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}