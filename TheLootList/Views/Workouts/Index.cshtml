@model IEnumerable<TriFalcon_Fitness.Models.Workout>

@{
    ViewData["Title"] = "Previous Workouts";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Previous Workouts</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-plus me-1"></i> Log New Workout
        </a>
    </div>

    <div class="table-responsive shadow-lg rounded">
        <table class="table table-dark table-hover align-middle">
            <thead class="bg-primary text-white">
                <tr>
                    <th class="ps-3 border-0">Date</th>
                    <th class="border-0">Type</th>
                    <th class="border-0">Exercise</th>
                    <th class="border-0">Performance</th>
                    <th class="text-center border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">@item.DateLogged.ToString("MMM dd, yyyy")</td>
                        <td>
                            <span class="badge @(item.ActivityType == "Strength" ? "bg-success" : "bg-info")">
                                @item.ActivityType
                            </span>
                        </td>
                        <td class="text-info fw-bold">@item.ExerciseName</td>
                        <td>
                            @if (item.ActivityType == "Strength")
                            {
                                <span>@item.Weight lbs × @item.Reps reps</span>
                            }
                            else
                            {
                                <span>@item.Distance mi in @item.DurationMinutes min</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning border-0 me-2" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted italic">No workouts found. Start your journey by logging one!</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>