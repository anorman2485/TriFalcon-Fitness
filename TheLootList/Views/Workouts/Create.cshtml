@model TriFalcon_Fitness.Models.Workout

@{
    ViewData["Title"] = "Log Activity";
}

<h1>Log Your Workout</h1>

<h4>Enter your details below</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ActivityType" class="control-label">Activity Type (e.g. Cardio, Strength)</label>
                <input asp-for="ActivityType" class="form-control" placeholder="Strength" />
                <span asp-validation-for="ActivityType" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ExerciseName" class="control-label">Exercise Name</label>
                <input asp-for="ExerciseName" class="form-control" placeholder="Bench Press" />
                <span asp-validation-for="ExerciseName" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col">
                    <div class="form-group mb-3">
                        <label asp-for="Weight" class="control-label"></label>
                        <input asp-for="Weight" class="form-control" />
                        <span asp-validation-for="Weight" class="text-danger"></span>
                    </div>
                </div>
                <div class="col">
                    <div class="form-group mb-3">
                        <label asp-for="Sets" class="control-label"></label>
                        <input asp-for="Sets" class="form-control" />
                        <span asp-validation-for="Sets" class="text-danger"></span>
                    </div>
                </div>
                <div class="col">
                    <div class="form-group mb-3">
                        <label asp-for="Reps" class="control-label"></label>
                        <input asp-for="Reps" class="form-control" />
                        <span asp-validation-for="Reps" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Distance" class="control-label">Distance (miles/km)</label>
                <input asp-for="Distance" class="form-control" />
                <span asp-validation-for="Distance" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DurationMinutes" class="control-label">Duration (minutes)</label>
                <input asp-for="DurationMinutes" class="form-control" />
                <span asp-validation-for="DurationMinutes" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Save Workout" class="btn btn-success btn-lg" />
                <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}