<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TriFalcon Fitness</title>
    @* Bootswatch Cyborg Theme *@
    <link rel="stylesheet" href="~/css/bootstrap-cyborg.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* FontAwesome for Professional Icons *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-bolt me-2"></i>TriFalcon Fitness
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Workouts" asp-action="Index">
                                <i class="fas fa-history me-1"></i> My Logs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-info fw-bold" asp-controller="Workouts" asp-action="Create">
                                <i class="fas fa-plus-circle me-1"></i> Log Activity
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Progress">
                                <i class="fas fa-chart-line me-1"></i> Progress
                            </a>
                        </li>

                        @* --- ASSIGNMENT 10 SECURITY LAYER START --- *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-user-shield me-1"></i> Admin Panel
                                </a>
                            </li>
                        }
                        @* --- ASSIGNMENT 10 SECURITY LAYER END --- *@
                    </ul>

                    @* Right side of Navbar *@
                    <ul class="navbar-nav">
                        <li class="nav-item me-2">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Settings">
                                <i class="fas fa-user-cog me-1"></i> Settings
                            </a>
                        </li>
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top bg-dark text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - <span class="text-primary fw-bold">TriFalcon Fitness</span> | Built for Performance
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>