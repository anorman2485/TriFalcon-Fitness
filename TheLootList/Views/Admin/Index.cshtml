@model IEnumerable<TriFalcon_Fitness.Models.ApplicationUser>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-dark rounded-3 border border-danger shadow-lg animate__animated animate__fadeIn">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="display-5 fw-bold text-danger">
                <i class="fas fa-user-shield me-2"></i>Admin Management
            </h1>
            <span class="badge bg-danger p-2">System Administrator Access</span>
        </div>
        
        <p class="text-light lead">Manage registered athletes and system security protocols.</p>
        <hr class="text-secondary" />

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-secondary">
                <thead class="text-info">
                    <tr>
                        <th>Full Name</th>
                        <th>Email / Username</th>
                        <th class="text-center">Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-bold">@user.FullName</td>
                            <td>@user.Email</td>
                            <td class="text-center">
                                <span class="badge bg-success bg-opacity-75">Active</span>
                            </td>
                            <td class="text-end">
                                @if (User.Identity?.Name != user.UserName)
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post"
                                          onsubmit="return confirm('WARNING: Are you sure you want to permanently remove this user? This action cannot be undone.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-user-times me-1"></i> Delete Athlete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Current Session</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light px-4">
                <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>
</div>